@page "/balance-sheet"
@inject IBalanceSheetService BalanceService
@inject IJSRuntime JS

<PageTitle>Balance Sheet Builder</PageTitle>

<h1>Balance Sheet Builder</h1>

<div class="row">
    <div class="col-md-6">
        <h3>Assets</h3>
        <button class="btn btn-sm btn-primary mb-2" @onclick="() => AddLineItem(assets)">Add Asset</button>
        @foreach (var item in assets)
        {
            <LineItemRow Item="item" OnRemove="() => assets.Remove(item)" />
        }
        <div class="mt-3 fw-bold fs-5">Total Assets: @TotalAssets.ToString("C2")</div>
    </div>

    <div class="col-md-6">
        <h3>Liabilities</h3>
        <button class="btn btn-sm btn-primary mb-2" @onclick="() => AddLineItem(liabilities)">Add Liability</button>
        @foreach (var item in liabilities)
        {
            <LineItemRow Item="item" OnRemove="() => liabilities.Remove(item)" />
        }
        <div class="mt-3 fw-bold fs-5">Total Liabilities: @TotalLiabilities.ToString("C2")</div>
    </div>
</div>

<div class="mt-4 p-3 bg-light rounded">
    <h3>Equity: <span class="text-success">@(TotalAssets - TotalLiabilities).ToString("C2")</span></h3>
</div>

<div class="mt-4">
    <button class="btn btn-success btn-lg me-3" @onclick="DownloadWord">📄 Download Balance Sheet (.docx)</button>

    <InputFile OnChange="UploadDocx" class="form-control d-inline w-auto" />
    @if (!string.IsNullOrEmpty(uploadedFile))
    {
        <div class="alert alert-success mt-3">Uploaded: @uploadedFile at @uploadTime</div>
    }
</div>

@code {
    private List<LineItem> assets = new();
    private List<LineItem> liabilities = new();
    private string? uploadedFile;
    private string? uploadTime;

    private decimal TotalAssets => assets.Sum(a => a.Amount);
    private decimal TotalLiabilities => liabilities.Sum(l => l.Amount);

    protected override void OnInitialized()
    {
        assets.Add(new LineItem { Name = "Cash", Amount = 125000 });
        assets.Add(new LineItem { Name = "Accounts Receivable", Amount = 35000 });
        liabilities.Add(new LineItem { Name = "Accounts Payable", Amount = 18000 });
    }

    private void AddLineItem(List<LineItem> list) => list.Add(new LineItem());

    private async Task DownloadWord()
    {
        var stream = await BalanceService.GenerateWordDocumentAsync(assets, liabilities);
        var base64 = Convert.ToBase64String(stream.ToArray());
        await JS.InvokeVoidAsync("downloadFile",
            $"BalanceSheet_{DateTime.Now:yyyy-MM-dd}.docx",
            base64,
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
    }

    private void UploadDocx(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File.Name;
        uploadTime = DateTime.Now.ToString("g");
    }
}